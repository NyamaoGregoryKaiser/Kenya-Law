# Kenya Law AI - Required for real AI and document indexing
GOOGLE_API_KEY=your_google_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here

# Optional legacy
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (PostgreSQL for app data: conversations, messages)
DATABASE_URL=postgresql://eversetech:passwd123@127.0.0.1:5432/kenyalaw_registry

# MongoDB (document details + document_processing status; for chat references)
MONGODB_URI=mongodb://localhost:27017/kenyalaw

# Qdrant (vector search; master collection used for RAG)
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=kenyalaw_cases
QDRANT_KL_LOOKUP_COLLECTION=KL_LOOKUP

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Application Configuration
DEBUG=True
SECRET_KEY=your_secret_key_here
